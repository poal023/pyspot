# chip specs
-t_chip                0.00015
-k_chip                130.0
-p_chip                1630300

# heat sink specs (Simulating Vapor Chamber + Copper)
-c_convec            140.4
-r_convec            0.1
-s_sink                0.06
-t_sink                0.0069
-k_sink                500.0     # Increased to account for Vapor Chamber efficiency
-p_sink                3.55e6    # Copper volumetric heat capacity

# heat spreader specs (Copper)
-s_spreader            0.03
-t_spreader            0.001
-k_spreader            400.0     # Standard Copper
-p_spreader            3.55e6

# interface material specs (High-performance TIM)
-t_interface        5.0e-05      # Slightly more realistic bond line thickness
-k_interface        5.0          # High-end TIM conductivity
-p_interface        4.0e6

